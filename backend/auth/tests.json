{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "testuser@vitonuse.ru", "password": "test123", "name": "Тест"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with valid credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "testuser@vitonuse.ru", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "testuser@vitonuse.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}